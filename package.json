{
  "name": "triple-triad-root",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "start": "sudo bash start-docker.sh",
    "stop": "sudo docker-compose down",
    "restart": "sudo docker-compose down && sudo bash start-docker.sh",
    "setup": "node scripts/setup-strapi.js",
    "test:api": "npm run test:api --prefix front",
    "dev:front": "npm run dev --prefix front",
    "build:front": "npm run build --prefix front",
    "docker:start": "sudo bash start-docker.sh",
    "docker:stop": "sudo docker-compose down",
    "docker:build": "sudo bash init.sh",
    "clean": "sudo bash clean.sh",
    "strapi:dev": "npm run develop --prefix back/strapi"
  }
}