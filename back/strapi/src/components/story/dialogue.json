{
  "collectionName": "components_story_dialogues",
  "info": {
    "displayName": "Dialogue",
    "description": "A single line of dialogue from a character"
  },
  "options": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": false
    },
    "sentence": {
      "type": "text",
      "required": true
    },
    "isNarration": {
      "type": "boolean",
      "default": false
    },
    "position": {
      "type": "enumeration",
      "enum": [
        "left",
        "right"
      ],
      "default": "left"
    },
    "card": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::card.card"
    }
  }
}
