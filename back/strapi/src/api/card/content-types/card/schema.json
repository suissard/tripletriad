{
  "kind": "collectionType",
  "collectionName": "cards",
  "info": {
    "singularName": "card",
    "pluralName": "cards",
    "displayName": "Card",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "element": {
      "type": "enumeration",
      "default": "None",
      "enum": [
        "None",
        "eau",
        "faille_dimensionnelle",
        "furtif",
        "hacking",
        "longue_portee",
        "obsidienne",
        "radiation",
        "reseau",
        "spore"
      ]
    },
    "elements": {
      "type": "json"
    },
    "faction": {
      "type": "enumeration",
      "default": "neutre",
      "enum": [
        "neutre",
        "Hégémonie martienne",
        "Exode pélagique",
        "Héritiers des cendres",
        "Omni-Réseau",
        "Chœur Synthétique",
        "Éveil Chthonien",
        "Incursion Dissonante",
        "Ferrailleurs de la Ceinture",
        "Fléau Spore"
      ]
    },
    "topValue": {
      "type": "string",
      "maxLength": 1,
      "required": true
    },
    "rightValue": {
      "type": "string",
      "maxLength": 1,
      "required": true
    },
    "bottomValue": {
      "type": "string",
      "maxLength": 1,
      "required": true
    },
    "leftValue": {
      "type": "string",
      "maxLength": 1,
      "required": true
    },
    "skills": {
      "type": "json"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "collectionName": {
      "type": "string"
    },
    "rarity": {
      "type": "enumeration",
      "default": "Common",
      "enum": [
        "Common",
        "Uncommon",
        "Rare",
        "Epic",
        "Legendary"
      ]
    },
    "storiesRewardedFrom": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::story.story",
      "mappedBy": "rewardCards"
    },
    "storyStepsRewardedFrom": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::story-step.story-step",
      "mappedBy": "rewardCards"
    }
  }
}
