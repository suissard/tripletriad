{
  "kind": "collectionType",
  "collectionName": "quest_templates",
  "info": {
    "singularName": "quest-template",
    "pluralName": "quest-templates",
    "displayName": "Quest Template",
    "description": "Base template for quests (e.g. daily quests)"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "code": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "target": {
      "type": "integer",
      "required": true,
      "min": 1
    },
    "reward": {
      "type": "integer",
      "required": false,
      "min": 0,
      "default": 0
    },
    "rewardCoins": {
      "type": "integer",
      "default": 0
    },
    "rewardGems": {
      "type": "integer",
      "default": 0
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "daily",
        "weekly",
        "monthly",
        "story",
        "play_games"
      ],
      "default": "daily",
      "required": true
    }
  }
}
