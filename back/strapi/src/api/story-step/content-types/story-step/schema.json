{
  "kind": "collectionType",
  "collectionName": "story_steps",
  "info": {
    "singularName": "story-step",
    "pluralName": "story-steps",
    "displayName": "Story Step",
    "description": "An individual step or battle in a story mode chapter"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "story": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::story.story",
      "inversedBy": "steps"
    },
    "startDialogue": {
      "type": "component",
      "repeatable": true,
      "component": "story.dialogue"
    },
    "endDialogue": {
      "type": "component",
      "repeatable": true,
      "component": "story.dialogue"
    },
    "rewardCards": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::card.card",
      "inversedBy": "storyStepsRewardedFrom"
    }
  }
}
