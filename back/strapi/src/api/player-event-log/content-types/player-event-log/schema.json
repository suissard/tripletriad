{
  "kind": "collectionType",
  "collectionName": "player_event_logs",
  "info": {
    "singularName": "player-event-log",
    "pluralName": "player-event-logs",
    "displayName": "Player Event Log",
    "description": "Log of player events used for statistics and quest progression"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "eventType": {
      "type": "enumeration",
      "enum": [
        "play_game",
        "win_game",
        "open_booster",
        "capture_card",
        "play_card",
        "play_card_element"
      ],
      "required": true
    },
    "relatedCard": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::card.card"
    },
    "relatedElement": {
      "type": "string"
    },
    "value": {
      "type": "integer",
      "default": 1
    },
    "timestamp": {
      "type": "datetime",
      "required": true
    }
  }
}
